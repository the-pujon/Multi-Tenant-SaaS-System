                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"test.user@example.com\"\n}"
                        },
                        "url": {
                            "raw": "{{apiBase}}/auth/resend-Verify-Email-Code",
                            "host": [
                                "{{apiBase}}"
                            ],
                            "path": [
                                "auth",
                                "resend-Verify-Email-Code"
                            ]
                        }
                    }
                },
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "let json = {};",
                                    "try { json = pm.response.json(); } catch (e) {}",
                                    "const accessTokenFromBody = json?.data?.accessToken;",
                                    "if (accessTokenFromBody) {",
                                    "  pm.environment.set('accessToken', accessTokenFromBody);",
                                    "}",
                                    "const setCookies = pm.response.headers.getAll('set-cookie') || [];",
                                    "const allCookies = setCookies.join('; ');",
                                    "const accessMatch = allCookies.match(/accessToken=([^;]+)/);",
                                    "const refreshMatch = allCookies.match(/refreshToken=([^;]+)/);",
                                    "if (accessMatch) {",
                                    "  pm.environment.set('accessToken', accessMatch[1]);",
                                    "}",
                                    "if (refreshMatch) {",
                                    "  pm.environment.set('refreshToken', refreshMatch[1]);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"test.user@example.com\",\n  \"password\": \"pass123\"\n}"
                        },
                        "url": {
                            "raw": "{{apiBase}}/auth/login",
                            "host": [
                                "{{apiBase}}"
                            ],
                            "path": [
                                "auth",
                                "login"
                            ]
                        }
                    }
                },
                {
                    "name": "Refresh Token",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{apiBase}}/auth/refresh-token",
                            "host": [
                                "{{apiBase}}"
                            ],
