                            "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test.user@example.com\",\n  \"phone\": \"01234567890\",\n  \"password\": \"pass123\"\n}"
                        },
                        "url": {
                            "raw": "{{apiBase}}/auth/signup",
                            "host": [
                                "{{apiBase}}"
                            ],
                            "path": [
