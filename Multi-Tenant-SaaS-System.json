                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"test.user@example.com\",\n  \"code\": \"ABC123\"\n}"
                        },
                        "url": {
                            "raw": "{{apiBase}}/auth/verify-email",
                            "host": [
                                "{{apiBase}}"
                            ],
                            "path": [
